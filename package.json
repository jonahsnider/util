{
	"name": "@jonahsnider/util",
	"version": "0.0.0-development",
	"description": "A useful collection of optimized utility functions",
	"homepage": "https://util.jonah.pw/",
	"license": "MIT",
	"author": {
		"name": "Jonah Snider",
		"email": "jonah@jonahsnider.com",
		"url": "https://jonahsnider.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/jonahsnider/util.git"
	},
	"files": [
		"dist"
	],
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.cts",
	"exports": {
		".": {
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		},
		"./package.json": "./package.json"
	},
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "vp pack",
		"deploy": "semantic-release",
		"docs": "typedoc --options ./typedoc.json",
		"lint": "vp check",
		"lint:fix": "vp check --fix",
		"test": "vp test run --no-isolate",
		"test:coverage": "vp test run --no-isolate --coverage",
		"test:dev": "vp test watch --no-isolate --ui",
		"validate-api": "api-extractor run",
		"validate-api:local": "api-extractor run --local --verbose"
	},
	"devDependencies": {
		"@microsoft/api-extractor": "7.58.7",
		"@types/node": "24.12.4",
		"@typescript/native-preview": "^7.0.0-dev.20260603.1",
		"@vitest/coverage-v8": "4.1.7",
		"@vitest/ui": "4.1.7",
		"@voidzero-dev/vite-plus-core": "0.1.22",
		"semantic-release": "25.0.3",
		"tsd": "0.33.0",
		"tslib": "2.8.1",
		"typedoc": "0.28.19",
		"typescript": "6.0.3",
		"vite": "8.0.14",
		"vite-plus": "0.1.22",
		"vitest": "4.1.7"
	},
	"engines": {
		"node": ">=16"
	},
	"packageManager": "yarn@6.0.0-rc.18"
}
